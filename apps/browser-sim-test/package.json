{
  "name": "@electron-benchmark/browser-sim-test",
  "version": "0.1.0",
  "private": true,
  "description": "复现用户问题：WebContentsView 与 launcher multi-window 主壳/tab 配置对齐",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "dist:win": "pnpm run build && electron-builder --win --x64"
  },
  "dependencies": {
    "@electron-memory/monitor": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "31.7.5",
    "electron-builder": "^25.1.8",
    "less": "^4.2.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.electronbenchmark.browser-sim-test",
    "productName": "Browser Sim Test",
    "directories": {
      "output": "release3"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-win-x64.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
