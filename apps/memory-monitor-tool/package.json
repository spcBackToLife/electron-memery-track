{
    "name": "@electron-benchmark/memory-monitor-tool",
    "version": "0.1.0",
    "private": true,
    "description": "Electron 内存监控工具 — 独立测试工具，关注持续性内存趋势与回归防护",
    "author": "electron-memery-demo",
    "main": "dist-electron/main.js",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "build:with-native": "node scripts/build-native.cjs && vite build",
        "dist": "pnpm run dist:win",
        "dist:win": "pnpm run build:with-native && electron-builder --win --x64",
        "dist:dir": "pnpm run build:with-native && electron-builder --win --dir"
    },
    "dependencies": {
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "recharts": "^2.12.0"
    },
    "devDependencies": {
        "@types/react": "^18.3.12",
        "@types/react-dom": "^18.3.1",
        "@vitejs/plugin-react": "^4.3.4",
        "electron": "^33.2.1",
        "electron-builder": "^25.1.8",
        "less": "^4.2.1",
        "typescript": "^5.6.3",
        "vite": "^6.0.3",
        "vite-plugin-electron": "^0.28.8"
    },
    "build": {
        "appId": "com.electronbenchmark.memory-monitor-tool",
        "productName": "Electron Memory Monitor Tool",
        "directories": {
            "output": "release2"
        },
        "asar": true,
        "asarUnpack": ["**/*.node"],
        "files": ["dist/**/*", "dist-electron/**/*", "native/memory_native.node"],
        "win": {
            "target": [{
                "target": "nsis",
                "arch": ["x64"]
            }]
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true
        }
    }
}